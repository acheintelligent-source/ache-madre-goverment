  // Update sidebar
  document.querySelectorAll('.nav-item').forEach(n => {
    if (n.textContent.includes(getTabLabel(tab))) n.classList.add('active');
  });
  
  state.activeTab = tab;
  
  if (tab === 'fintech') showFintechTab(state.activeFintechTab);
}

function getTabLabel(tab) {
  const labels = { dashboard:'Dashboard', 'ai-hub':'Hub', legal:'Legal', government:'Gobierno', autoprog:'Autoprogramación', fintech:'Motor' };
  return labels[tab] || '';
}

function showTabFintech(sub) {
  showTab('fintech');
  state.activeFintechTab = sub;
  
  ['revenue','wallet','payments','bank'].forEach(s => {
    const el = document.getElementById('fintech-' + s);
    if (el) el.style.display = s === sub ? 'block' : 'none';
  });
  
  const headings = {
    revenue: 'MOTOR DE INGRESOS ACHE',
    wallet: 'CRYPTO WALLET — COOPECRUCENOS',
    payments: 'PAGOS Y TRANSFERENCIAS',
    bank: 'BANCO ACHE — INFRAESTRUCTURA'
  };
