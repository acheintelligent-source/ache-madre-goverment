}

// ── ACHE API CALLS ──────────────────────────────────
async function callACHE(endpoint) {
  const terminal = document.getElementById('terminal-output');
  addTermLine(`<span class="term-prompt">ache@gonzaga:~$ </span><span class="term-cmd">curl ${ACHE_BASE}${endpoint}</span>`);
  
  try {
    const res = await fetch(ACHE_BASE + endpoint, { 
      signal: AbortSignal.timeout(3000),
      mode: 'cors'
    });
    const data = await res.json();
    addTermLine(`<span class="term-ok">✓ ${JSON.stringify(data).substring(0,120)}...</span>`);
    notify('✅', `ACHE responde: ${endpoint}`);
  } catch(e) {
    addTermLine(`<span class="term-warn">⚡ Servidor local en localhost:8080 — ejecuta: python boot.py</span>`);
    addTermLine(`<span class="term-out">  Respuesta simulada: {"status":"OK","cell":"GONZAGA-CBM-OMEGA-001","trl":5,"ccps":13}</span>`);
    notify('⚡', 'ACHE local: inicia python boot.py');
  }
}

// ── CHAT SYSTEMS ──────────────────────────────────
const acheResponses = {
  default: [
    '⬡ Evento registrado en cadena SHA-256. TRL-5 operacional. ¿Algo más?',
    '⬡ Consultando CCPs... CCP-01 (Soberanía Humana) activo. Aprobación requerida para acciones críticas.',
    '⬡ AcheMemory: append-only SQLite. Ningún evento puede borrarse. Cadena íntegra.',
    '⬡ Sincronizando con Supabase... 7 eventos en cloud. localhost:8080 activo.',
    '⬡ ACHE-MESH: 5 nodos simulados. GONZAGA-CBM-Ω-001 es el nodo primario del cantón.',
  ],
  estado: '⬡ TRL: 5/9 | Eventos: 847 | CCPs: 13 | Módulos activos: boot, telegram, sync, API | Supabase: online | ngrok: activo',
  factura: '⬡ Para facturar: /factura [cliente] [monto]. Requiere ache_hacienda.py instalado. XML v4.3, IVA 13%, clave 50 dígitos. Pendiente configurar credenciales ATV.',
  iva: (txt) => {
    const num = parseFloat(txt.match(/[\d.,]+/)?.[0] || 0);
    if (num) return `⬡ IVA (13%): ₡${(num*0.13).toLocaleString()} | Total: ₡${(num*1.13).toLocaleString()}`;
    return '⬡ Indica el monto: ej "iva 50000"';
  },
  principios: '⬡ 10 CCPs activos: 1-Soberanía Humana | 2-Memoria Inamovible | 3-Transparencia Total | 4-Offline-First | 5-Sin Dependencia Única | 6-Mínimo Impacto | 7-Equidad Digital | 8-Gobernanza Cooperativa | 9-Escalabilidad Federada | 10-Misión Social Primaria',
};

function getACHEResponse(text) {
  const t = text.toLowerCase();
  if (t.includes('estado') || t.includes('status')) return acheResponses.estado;
  if (t.includes('factura')) return acheResponses.factura;
  if (t.includes('iva') || t.includes('impuesto')) return acheResponses.iva(t);
  if (t.includes('principio') || t.includes('ccp')) return acheResponses.principios;
  return acheResponses.default[Math.floor(Math.random() * acheResponses.default.length)];
}

async function sendACHE() {
  const input = document.getElementById('ache-input');
  const msgs = document.getElementById('ache-msgs');
  const text = input.value.trim();
  if (!text) return;
  
  addMsg(msgs, text, 'user');
  input.value = '';
  
  const thinking = addMsg(msgs, '⬡ procesando ciclo cognitivo...', 'thinking');
  
  // Try real API first
  let response;
  try {
    const res = await fetch(`${ACHE_BASE}/recomendar`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ contexto: text, urgencia: 'normal' }),
      signal: AbortSignal.timeout(2000),
      mode: 'cors'
    });
    const data = await res.json();
    response = data.recomendacion || data.result || JSON.stringify(data);
  } catch(e) {
    await new Promise(r => setTimeout(r, 800));
    response = getACHEResponse(text);
  }
  
  thinking.remove();
  addMsg(msgs, response, 'bot');
  state.events++;
  document.getElementById('kpi-events').textContent = state.events.toLocaleString();
}

