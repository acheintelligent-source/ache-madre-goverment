  const input = document.getElementById('claude-input');
  const msgs = document.getElementById('claude-msgs');
  const text = input.value.trim();
  if (!text) return;
  
  addMsg(msgs, text, 'user');
  input.value = '';
  const thinking = addMsg(msgs, '◎ Procesando con lógica ACHE...', 'thinking');
  
  await new Promise(r => setTimeout(r, 900));
  thinking.remove();
  
  const responses = [
    `Para el contexto de ACHE y COOPECRUCENOS: "${text}" — te recomiendo consultar primero MASTER.md (los 10 CCPs) y verificar que cualquier acción pase por HumanCheckpoint si es irreversible.`,
    `Analizando tu consulta en el contexto de La Cruz, Guanacaste: el CCP-07 (Equidad Digital) indica que la solución debe funcionar para el usuario de menor capacidad tecnológica. ¿Cómo aplica eso aquí?`,
    `Desde la perspectiva del Digital Cities Challenge: tu propuesta debe mostrar TRL 7 al mes 12. Para "${text}", el camino más directo es documentar el impacto medible en los 8,000 beneficiarios proyectados.`,
  ];
  
  addMsg(msgs, responses[Math.floor(Math.random() * responses.length)], 'bot');
}

async function sendMulti() {
  const input = document.getElementById('multi-input');
  const msgs = document.getElementById('multi-msgs');
  const text = input.value.trim();
  if (!text) return;
  
  addMsg(msgs, text, 'user');
  input.value = '';
  const thinking = addMsg(msgs, '🕸 Enrutando a agentes...', 'thinking');
  
  await new Promise(r => setTimeout(r, 600));
  thinking.remove();
  
  const t = text.toLowerCase();
  let agent, response;
  
  if (t.includes('segur') || t.includes('alert') || t.includes('emerg')) {
    agent = '🛡 SAFETY';
    response = 'Recibida alerta. Clasificando... Prioridad MEDIA. Notificando coordinador municipal. Registrando en cadena SHA-256.';
  } else if (t.includes('factura') || t.includes('pago') || t.includes('venta')) {
    agent = '💰 COMMERCE';
    response = 'Procesando transacción. Validando IVA 13% (Ley 9635). Generando XML v4.3 para Hacienda CR. HumanCheckpoint: ¿confirmas el monto?';
  } else if (t.includes('report') || t.includes('panel') || t.includes('datos')) {
    agent = '🏛 GOVERNANCE';
    response = 'Generando reporte. 847 eventos en cadena. 127 usuarios activos. Sincronizado con Municipalidad La Cruz. Dashboard actualizado.';
  } else {
    agent = '🌐 INCLUSION';
    response = 'Tarea recibida. Verificando disponibilidad en terminales offline. Sitios activos: Cooperativa, Municipalidad. Liceo: planificado.';
  }
  
  addMsg(msgs, `[${agent}] ${response}`, 'bot');
}

// ── UTILS ──────────────────────────────────────────
function addMsg(container, text, type) {
  const div = document.createElement('div');
  div.className = 'msg ' + type;
  div.innerHTML = text;
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
  return div;
}

function addTermLine(html) {
  const terminal = document.getElementById('terminal-output');
  if (!terminal) return;
  const div = document.createElement('div');
  div.className = 'term-line';
  div.innerHTML = html;
  terminal.appendChild(div);
  terminal.scrollTop = terminal.scrollHeight;
}

function notify(icon, text) {
  const el = document.getElementById('notif');
  document.getElementById('notif-icon').textContent = icon;
  document.getElementById('notif-text').textContent = text;
  el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 3500);
}

