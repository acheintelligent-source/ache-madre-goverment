    { delay: 900, html: '<span class="term-ok">✓ AcheMemory: ache_cell.db abierta (append-only)</span>' },
    { delay: 1200, html: '<span class="term-ok">✓ RulesEngine: 42 reglas evaluadas</span>' },
    { delay: 1500, html: '<span class="term-ok">✓ FastAPI: http://localhost:8080 activo</span>' },
    { delay: 1800, html: '<span class="term-ok">✓ Telegram Bot: polling iniciado</span>' },
    { delay: 2100, html: '<span class="term-ok">✓ Supabase sync: modo --watch 300s</span>' },
