// ── MODALS / WARNINGS ──────────────────────────────
function showWarning(type) {
  const configs = {
    crypto: {
      title: '⚠ Operación Crypto — HumanCheckpoint (CCP-01)',
      warning: 'Las transacciones de criptomonedas son IRREVERSIBLES. Esta operación no puede deshacerse una vez confirmada.',
      info: 'Según CCP-01 (Soberanía Humana), ACHE requiere confirmación humana explícita para todas las transacciones financieras. Esta interfaz es modo DEMO — para operación real se requiere licencia SUGEF.'
    },
    payment: {
      title: '⚠ Transferencia Bancaria — HumanCheckpoint (CCP-01)',
      warning: 'Las transferencias SINPE son IRREVERSIBLES una vez procesadas por el BCCR.',
      info: 'ACHE registrará esta transacción en la cadena SHA-256 inamovible. El HumanCheckpoint (CCP-01) requiere tu confirmación. En modo DEMO: ningún dinero real se mueve.'
    }
  };
  
  const c = configs[type];
  document.getElementById('modal-title').textContent = c.title;
  document.getElementById('modal-warning').textContent = c.warning;
  document.getElementById('modal-info').textContent = c.info;
  document.getElementById('modal').classList.add('show');
}

function closeModal() {
  document.getElementById('modal').classList.remove('show');
}

function confirmModal() {
  closeModal();
  const ev = { type: 'CHECKPOINT', text: 'Acción financiera aprobada por humano', color: 'gold', agent: 'human', hash: 'sha256:' + Math.random().toString(36).substring(2,10) + '...' + Math.random().toString(36).substring(2,6) };
  sampleEvents.unshift(ev);
  if (sampleEvents.length > 8) sampleEvents.pop();
  renderChainEvents();
  notify('✅', 'HumanCheckpoint completado · Registrado en cadena');
}

// ── TRANSACTIONS ──────────────────────────────────
function renderTransactions() {
  const txs = [
    { type: '↑', desc: 'Hotel — 3 hab.', amount: '₡240,000', time: '08:32', color: 'var(--accent2)' },
    { type: '↑', desc: 'Supermercado #1', amount: '₡187,500', time: '09:15', color: 'var(--accent2)' },
    { type: '↓', desc: 'Prov. alimentaria', amount: '₡95,000', time: '10:00', color: 'var(--red)' },
    { type: '↑', desc: 'Factura electrónica', amount: '₡52,000', time: '11:22', color: 'var(--accent2)' },
  ];
  
  const container = document.getElementById('tx-list');
  if (!container) return;
  
  container.innerHTML = txs.map(tx => `
    <div class="chain-event">
      <div style="width:24px;height:24px;border-radius:50%;background:${tx.type==='↑'?'rgba(0,255,157,0.15)':'rgba(255,45,85,0.15)'};display:flex;align-items:center;justify-content:center;font-size:12px;color:${tx.color};flex-shrink:0">${tx.type}</div>
      <div class="event-text">
        <div class="event-type">${tx.desc}</div>
        <div class="event-meta" style="color:${tx.color};font-weight:600">${tx.amount}</div>
        <div class="event-hash">${tx.time} hoy · Registrado en cadena SHA-256</div>
      </div>
    </div>
  `).join('');
}

// ── LIVE UPDATES ──────────────────────────────────
function updateKPIs() {
  const el = document.getElementById('kpi-revenue');
  if (el) {
    const base = 280000 + Math.floor(Math.random() * 20000);
    el.textContent = '₡' + (base/1000).toFixed(0) + 'K';
  }
}

// ── INIT ──────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  renderChainEvents();
  renderTransactions();
  
  // Live KPI updates
  setInterval(updateKPIs, 8000);
  
  // Live event counter
  setInterval(() => {
    state.events += Math.random() > 0.7 ? 1 : 0;
    const el = document.getElementById('kpi-events');
    if (el) el.textContent = state.events.toLocaleString();
  }, 5000);
  
  // Add boot event to terminal after load
  setTimeout(() => {
    addTermLine('<span class="term-ok">✓ ACHE Madre Government UI cargado</span>');
    addTermLine('<span class="term-info">ℹ Conectando a localhost:8080...</span>');
    
    fetch(ACHE_BASE + '/health', { signal: AbortSignal.timeout(2000), mode: 'cors' })
      .then(r => r.json())
      .then(d => addTermLine('<span class="term-ok">✓ Servidor ACHE respondiendo: ' + JSON.stringify(d) + '</span>'))
      .catch(() => addTermLine('<span class="term-warn">⚡ localhost:8080 no responde · ejecuta: python boot.py</span>'));
  }, 500);
  
  // Initial notification
  setTimeout(() => notify('⬡', 'ACHE Madre Government · Sistema iniciado'), 1000);
});
</script>
