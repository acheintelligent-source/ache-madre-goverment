<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ACHE MADRE — Plataforma de Gobernanza Costa Rica</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800;900&family=Rajdhani:wght@300;400;600;700&family=JetBrains+Mono:wght@300;400;600&display=swap" rel="stylesheet">
<style>
:root {
  --black: #030508;
  --deep: #050c14;
  --surface: #0a1628;
  --card: #0d1f35;
  --border: #1a3050;
  --accent1: #00d4ff;
  --accent2: #00ff9d;
  --accent3: #ff6b35;
  --gold: #ffd700;
  --red: #ff2d55;
  --purple: #a855f7;
  --text: #e2eaf4;
  --muted: #5a7a99;
  --glow1: rgba(0,212,255,0.15);
  --glow2: rgba(0,255,157,0.1);
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: 'Rajdhani', sans-serif;
  background: var(--black);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* GRID BACKGROUND */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
  z-index: 0;
}

/* SCAN LINE */
body::after {
  content: '';
  position: fixed;
  top: -100%;
  left: 0;
  right: 0;
  height: 200px;
  background: linear-gradient(transparent, rgba(0,212,255,0.04), transparent);
  animation: scan 8s linear infinite;
  pointer-events: none;
  z-index: 1;
}

@keyframes scan { to { top: 100%; } }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
@keyframes glow { 0%,100%{box-shadow:0 0 10px var(--accent1)} 50%{box-shadow:0 0 30px var(--accent1), 0 0 60px rgba(0,212,255,0.3)} }
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
@keyframes slideIn { from{opacity:0;transform:translateX(-20px)} to{opacity:1;transform:translateX(0)} }
@keyframes fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
@keyframes spin { to{transform:rotate(360deg)} }
@keyframes countUp { from{opacity:0;transform:scale(0.8)} to{opacity:1;transform:scale(1)} }

/* ── HEADER ─────────────────────────────────── */
header {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 64px;
  background: rgba(3,5,8,0.95);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  z-index: 1000;
  backdrop-filter: blur(20px);
}

.logo {
  display: flex;
  align-items: center;
  gap: 12px;
}

.logo-hex {
  width: 40px; height: 40px;
  background: linear-gradient(135deg, var(--accent1), var(--accent2));
  clip-path: polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Orbitron', monospace;
  font-size: 12px;
  font-weight: 900;
  color: var(--black);
  animation: float 4s ease-in-out infinite;
}

.logo-text {
  font-family: 'Orbitron', monospace;
  font-weight: 800;
  font-size: 18px;
  background: linear-gradient(90deg, var(--accent1), var(--accent2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: 2px;
}

.logo-sub {
  font-family: 'Rajdhani', sans-serif;
  font-size: 10px;
  color: var(--muted);
  letter-spacing: 3px;
  text-transform: uppercase;
  line-height: 1;
}

.header-status {
  display: flex;
  align-items: center;
  gap: 20px;
}

.status-pill {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  border: 1px solid;
  border-radius: 20px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 1px;
}

.status-pill.online { border-color: var(--accent2); color: var(--accent2); }
.status-pill.warning { border-color: var(--gold); color: var(--gold); }

.dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; animation: pulse 1.5s infinite; }

.cell-id {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  color: var(--muted);
  letter-spacing: 1px;
}

/* ── SIDEBAR ─────────────────────────────────── */
aside {
  position: fixed;
  top: 64px; left: 0; bottom: 0;
  width: 220px;
  background: rgba(5,12,20,0.98);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  z-index: 100;
  overflow-y: auto;
}

.nav-section {
  padding: 16px 0 8px;
}

.nav-label {
  padding: 0 20px 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  color: var(--muted);
  letter-spacing: 3px;
  text-transform: uppercase;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 20px;
  cursor: pointer;
  border-left: 3px solid transparent;
  transition: all 0.2s;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.5px;
  position: relative;
}

.nav-item:hover { background: var(--glow1); color: var(--accent1); }
.nav-item.active {
  border-left-color: var(--accent1);
  background: var(--glow1);
  color: var(--accent1);
}

.nav-item .icon { font-size: 16px; width: 20px; text-align: center; }

.nav-badge {
  margin-left: auto;
  padding: 1px 6px;
  border-radius: 10px;
  font-size: 9px;
  font-family: 'JetBrains Mono', monospace;
}

.badge-green { background: rgba(0,255,157,0.2); color: var(--accent2); }
.badge-orange { background: rgba(255,107,53,0.2); color: var(--accent3); }
.badge-blue { background: rgba(0,212,255,0.2); color: var(--accent1); }
.badge-gold { background: rgba(255,215,0,0.2); color: var(--gold); }

/* ── MAIN ─────────────────────────────────── */
main {
  margin-left: 220px;
  margin-top: 64px;
  min-height: calc(100vh - 64px);
  position: relative;
  z-index: 2;
}

.tab-content { display: none; }
.tab-content.active { display: block; animation: fadeUp 0.3s ease; }

/* ── DASHBOARD ─────────────────────────────── */
.dashboard {
  padding: 24px;
}

.dash-title {
  font-family: 'Orbitron', monospace;
  font-size: 13px;
  color: var(--muted);
  letter-spacing: 4px;
  text-transform: uppercase;
  margin-bottom: 4px;
}

.dash-heading {
  font-family: 'Orbitron', monospace;
  font-size: 28px;
  font-weight: 800;
  background: linear-gradient(90deg, var(--text), var(--accent1));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 24px;
}

/* KPI GRID */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 24px;
}

.kpi-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s, border-color 0.2s;
}

.kpi-card:hover { transform: translateY(-2px); }
.kpi-card.blue:hover { border-color: var(--accent1); }
.kpi-card.green:hover { border-color: var(--accent2); }
.kpi-card.orange:hover { border-color: var(--accent3); }
.kpi-card.gold:hover { border-color: var(--gold); }

.kpi-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
}
.kpi-card.blue::before { background: var(--accent1); }
.kpi-card.green::before { background: var(--accent2); }
.kpi-card.orange::before { background: var(--accent3); }
.kpi-card.gold::before { background: var(--gold); }

.kpi-label {
  font-size: 11px;
  color: var(--muted);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 8px;
  font-family: 'JetBrains Mono', monospace;
}

.kpi-value {
  font-family: 'Orbitron', monospace;
  font-size: 26px;
  font-weight: 700;
  margin-bottom: 4px;
  animation: countUp 0.5s ease;
}

.kpi-card.blue .kpi-value { color: var(--accent1); }
.kpi-card.green .kpi-value { color: var(--accent2); }
.kpi-card.orange .kpi-value { color: var(--accent3); }
.kpi-card.gold .kpi-value { color: var(--gold); }

.kpi-sub { font-size: 12px; color: var(--muted); }
.kpi-trend { font-size: 11px; margin-top: 6px; }
.kpi-trend.up { color: var(--accent2); }
.kpi-trend.down { color: var(--red); }

/* MAIN GRID */
.main-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 16px;
  margin-bottom: 24px;
}

.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}

.card-header {
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-title {
  font-family: 'Orbitron', monospace;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 2px;
  color: var(--accent1);
  text-transform: uppercase;
}

.card-body { padding: 20px; }

/* CHAIN EVENTS */
.chain-event {
  display: flex;
  gap: 12px;
  margin-bottom: 12px;
  font-size: 13px;
  animation: slideIn 0.3s ease;
}

.event-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  margin-top: 5px;
  flex-shrink: 0;
}

.event-dot.green { background: var(--accent2); box-shadow: 0 0 6px var(--accent2); }
.event-dot.blue { background: var(--accent1); box-shadow: 0 0 6px var(--accent1); }
.event-dot.orange { background: var(--accent3); }
.event-dot.gold { background: var(--gold); }

.event-text { flex: 1; }
.event-type { font-weight: 600; }
.event-meta { font-size: 11px; color: var(--muted); font-family: 'JetBrains Mono', monospace; }
.event-hash { font-size: 9px; color: var(--muted); font-family: 'JetBrains Mono', monospace; letter-spacing: 1px; }

/* MODULE STATUS */
.module-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
}
.module-item:last-child { border-bottom: none; }

.mod-status {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.mod-status.ok { background: var(--accent2); animation: pulse 2s infinite; }
.mod-status.warn { background: var(--gold); animation: pulse 1s infinite; }
.mod-status.off { background: var(--muted); }

.mod-name { font-weight: 600; flex: 1; }
.mod-tag {
  font-size: 10px;
  padding: 2px 8px;
  border-radius: 4px;
  font-family: 'JetBrains Mono', monospace;
}
.mod-tag.trl5 { background: rgba(0,212,255,0.15); color: var(--accent1); }
.mod-tag.building { background: rgba(255,215,0,0.15); color: var(--gold); }
.mod-tag.planned { background: rgba(90,122,153,0.2); color: var(--muted); }

/* ── AI HUB ─────────────────────────────────── */
.ai-hub { padding: 24px; }

.ai-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 24px;
}

.ai-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  height: 520px;
  transition: border-color 0.2s;
}

.ai-card:hover { border-color: var(--accent1); }

.ai-card-header {
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 10px;
}

.ai-logo {
  width: 32px; height: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 900;
}

.ai-name { font-family: 'Orbitron', monospace; font-size: 12px; font-weight: 600; }
.ai-model { font-size: 10px; color: var(--muted); font-family: 'JetBrains Mono', monospace; }

.ai-iframe-wrap {
  flex: 1;
  position: relative;
  overflow: hidden;
}

.ai-iframe-wrap iframe {
  width: 100%;
  height: 100%;
  border: none;
  background: var(--surface);
}

.ai-chat-local {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 12px;
  gap: 8px;
  overflow: hidden;
}

.chat-messages {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 4px;
}

.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-track { background: transparent; }
.chat-messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

.msg {
  padding: 8px 12px;
  border-radius: 8px;
  font-size: 13px;
  line-height: 1.5;
  max-width: 90%;
  animation: fadeUp 0.2s ease;
}

.msg.bot {
  background: var(--surface);
  border: 1px solid var(--border);
  align-self: flex-start;
}

.msg.user {
  background: rgba(0,212,255,0.1);
  border: 1px solid rgba(0,212,255,0.3);
  align-self: flex-end;
  color: var(--accent1);
}

.msg.thinking {
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--muted);
  font-style: italic;
  align-self: flex-start;
  font-size: 12px;
}

.chat-input-row {
  display: flex;
  gap: 8px;
}

.chat-input {
  flex: 1;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 8px 12px;
  color: var(--text);
  font-family: 'Rajdhani', sans-serif;
  font-size: 13px;
  outline: none;
  transition: border-color 0.2s;
}

.chat-input:focus { border-color: var(--accent1); }
.chat-input::placeholder { color: var(--muted); }

.btn-send {
  padding: 8px 14px;
  background: var(--accent1);
  color: var(--black);
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 700;
  font-size: 14px;
  transition: opacity 0.2s;
}

.btn-send:hover { opacity: 0.8; }

/* ── FINTECH ─────────────────────────────────── */
.fintech { padding: 24px; }

.fin-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.fin-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}

/* WALLET */
.wallet-display {
  padding: 24px;
  text-align: center;
  background: linear-gradient(135deg, rgba(0,212,255,0.08), rgba(0,255,157,0.05));
  border-bottom: 1px solid var(--border);
}

.wallet-addr {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--muted);
  margin-bottom: 8px;
  letter-spacing: 1px;
}

.wallet-balance-label { font-size: 12px; color: var(--muted); margin-bottom: 4px; }

.wallet-balance {
  font-family: 'Orbitron', monospace;
  font-size: 32px;
  font-weight: 800;
  color: var(--gold);
  margin-bottom: 4px;
}

.wallet-usd { font-size: 14px; color: var(--muted); }

.crypto-list { padding: 16px 20px; }

.crypto-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
}
.crypto-row:last-child { border-bottom: none; }

.crypto-icon {
  width: 32px; height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 700;
}

.crypto-name { flex: 1; }
.crypto-sym { font-size: 11px; color: var(--muted); font-family: 'JetBrains Mono', monospace; }
.crypto-amount { font-family: 'JetBrains Mono', monospace; font-size: 13px; }
.crypto-val { font-size: 11px; color: var(--muted); }

/* PAYMENTS */
.payment-form { padding: 20px; }

.form-group { margin-bottom: 16px; }

.form-label {
  display: block;
  font-size: 11px;
  color: var(--muted);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 6px;
  font-family: 'JetBrains Mono', monospace;
}

.form-input, .form-select {
  width: 100%;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 14px;
  color: var(--text);
  font-family: 'Rajdhani', sans-serif;
  font-size: 14px;
  outline: none;
  transition: border-color 0.2s;
}

.form-input:focus, .form-select:focus { border-color: var(--accent1); }
.form-select option { background: var(--card); }

.btn-primary {
  width: 100%;
  padding: 12px;
  background: linear-gradient(135deg, var(--accent1), var(--accent2));
  color: var(--black);
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-family: 'Orbitron', monospace;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 2px;
  transition: opacity 0.2s, transform 0.1s;
}

.btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
.btn-primary:active { transform: translateY(0); }

/* REVENUE ENGINE */
.revenue-engine { padding: 24px; }

.revenue-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16px;
  margin-bottom: 24px;
}

.rev-source {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  position: relative;
}

.rev-icon { font-size: 28px; margin-bottom: 10px; }
.rev-name { font-size: 13px; font-weight: 600; color: var(--muted); margin-bottom: 4px; letter-spacing: 1px; }
.rev-amount { font-family: 'Orbitron', monospace; font-size: 22px; color: var(--accent2); font-weight: 700; }
.rev-period { font-size: 11px; color: var(--muted); font-family: 'JetBrains Mono', monospace; }

.rev-bar {
  margin-top: 10px;
  height: 4px;
  background: var(--border);
  border-radius: 2px;
  overflow: hidden;
}

.rev-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent1), var(--accent2));
  border-radius: 2px;
  transition: width 1s ease;
}

/* LEGAL BOT */
.legal-hub { padding: 24px; }

.legal-frame-wrap {
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--border);
  height: 600px;
}

.legal-frame-wrap iframe {
  width: 100%;
  height: 100%;
  border: none;
}

/* AUTOPROGRAMMING */
.auto-prog { padding: 24px; }

.terminal {
  background: #000;
  border: 1px solid var(--accent2);
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 0 30px rgba(0,255,157,0.1);
}

.terminal-bar {
  padding: 10px 16px;
  background: rgba(0,255,157,0.05);
  border-bottom: 1px solid var(--accent2);
  display: flex;
  align-items: center;
  gap: 8px;
}

.term-dot { width: 10px; height: 10px; border-radius: 50%; }

.terminal-body {
  padding: 20px;
  height: 400px;
  overflow-y: auto;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  line-height: 1.7;
}

.term-line { animation: slideIn 0.3s ease; }
.term-prompt { color: var(--accent2); }
.term-cmd { color: var(--text); }
.term-out { color: var(--muted); }
.term-ok { color: var(--accent2); }
.term-warn { color: var(--gold); }
.term-err { color: var(--red); }
.term-info { color: var(--accent1); }
.cursor { animation: pulse 1s infinite; }

.agent-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-top: 20px;
}

.agent-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 16px;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
}

.agent-card:hover {
  border-color: var(--accent1);
  background: var(--glow1);
  transform: translateY(-2px);
}

.agent-icon { font-size: 24px; margin-bottom: 8px; }
.agent-name { font-size: 12px; font-weight: 600; color: var(--accent1); font-family: 'Orbitron', monospace; margin-bottom: 4px; }
.agent-status { font-size: 10px; color: var(--muted); font-family: 'JetBrains Mono', monospace; }

.agent-card.running { border-color: var(--accent2); animation: glow 2s infinite; }
.agent-card.running .agent-name { color: var(--accent2); }

/* GOVT */
.govt-hub { padding: 24px; }

.ministry-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.ministry-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  cursor: pointer;
  transition: all 0.2s;
}

.ministry-card:hover {
  border-color: var(--accent1);
  transform: translateY(-2px);
