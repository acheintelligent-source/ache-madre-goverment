}

function runAutoScan() {
  const modules = ['boot.py', 'ache_bot.py', 'ache_sync.py', 'server.py', 'swarm_sim.py', 'ache_hacienda.py'];
  modules.forEach((m, i) => {
    setTimeout(() => {
      const ok = m !== 'ache_hacienda.py';
      addTermLine(`<span class="${ok?'term-ok':'term-warn'}">${ok?'✓':'⚡'} ${m}: ${ok?'OK':'pendiente instalación'}</span>`);
    }, i * 400);
  });
  notify('🔍', 'Escaneando módulos ACHE...');
}

function runSync() {
  addTermLine('<span class="term-prompt">ache@gonzaga:~$ </span><span class="term-cmd">python ache_sync.py --status</span>');
  setTimeout(() => addTermLine('<span class="term-ok">✓ LOCAL: 847 eventos · 12 facturas</span>'), 300);
  setTimeout(() => addTermLine('<span class="term-ok">✓ SUPABASE: ache_events:847 · ache_facturas:12</span>'), 600);
  setTimeout(() => addTermLine('<span class="term-info">ℹ Próximo sync en 287 segundos</span>'), 900);
  notify('☁', 'Supabase: sincronizado');
}

